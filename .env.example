# MySQL Configuration (XAMPP)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=biolight_monitor

# Server Configuration
HTTP_PORT=3000
MLLP_PORT=6201

# Biolight Monitor — IP address of the physical monitor on your network.
# The monitor runs as a TCP server; our app connects to it as a client.
# Comment out to use client mode (monitor connects to us instead).
MONITOR_IP=192.168.0.194
MONITOR_PORT=6201

# Simulator
SIM_INTERVAL_MS=5000
